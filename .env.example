DATABASE_URL="postgresql://user:password@localhost:5432/noter?schema=public"

# Only needed when DATABASE_URL is a pooled connection (e.g. Neon's "-pooler"
# connection string). Set this to the same database's direct/unpooled
# connection string so migrations can run — pooled connections don't support
# the session lock `prisma migrate deploy` needs. Not needed for a plain
# local Postgres instance.
DIRECT_URL=""

# Password required to log in to the app. Change this before deploying.
APP_PASSWORD="changeme"

# Random secret used to sign the login session cookie. Generate your own with:
# openssl rand -base64 32
AUTH_SECRET=""
