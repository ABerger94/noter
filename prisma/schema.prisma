generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Course {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  notes     Note[]

  @@unique([name])
}

model Tag {
  id    String     @id @default(cuid())
  name  String     @unique
  notes NoteTag[]
}

model Note {
  id          String       @id @default(cuid())
  title       String
  content     String       @default("")
  courseId    String?
  course      Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  tags        NoteTag[]
  attachments Attachment[]
  linksFrom   NoteLink[]   @relation("NoteLinkA")
  linksTo     NoteLink[]   @relation("NoteLinkB")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([courseId])
}

// Undirected link between two notes. To keep a pair unique regardless of
// which note initiated the link, callers always store noteAId < noteBId.
model NoteLink {
  id        String   @id @default(cuid())
  noteAId   String
  noteBId   String
  noteA     Note     @relation("NoteLinkA", fields: [noteAId], references: [id], onDelete: Cascade)
  noteB     Note     @relation("NoteLinkB", fields: [noteBId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([noteAId, noteBId])
  @@index([noteBId])
}

model NoteTag {
  noteId String
  tagId  String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

model Attachment {
  id        String   @id @default(cuid())
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String
  data      Bytes
  size      Int
  createdAt DateTime @default(now())

  @@index([noteId])
}
